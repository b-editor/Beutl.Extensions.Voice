<UserControl x:Class="Beutl.Extensions.Voice.Views.TtsTabView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:Beutl.Extensions.Voice.Models"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:viewModels="using:Beutl.Extensions.Voice.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:CompileBindings="True"
             x:DataType="viewModels:TtsTabViewModel"
             mc:Ignorable="d">
    <Grid RowDefinitions="40,*">
        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
            <TextBlock Margin="10,0,0,0"
                       VerticalAlignment="Center"
                       Text="テキスト読み上げ" />
        </Border>
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="10">
                <ui:InfoBar Title="警告"
                            Margin="0,0,0,8"
                            IsOpen="{Binding !IsVoiceVoxInstalled.Value}"
                            IsVisible="{Binding !IsVoiceVoxInstalled.Value}"
                            Message="VOICEVOXがインストールされていません。"
                            Severity="Warning">
                    <ui:InfoBar.ActionButton>
                        <Button Click="DownloadVoiceVox">インストール</Button>
                    </ui:InfoBar.ActionButton>
                </ui:InfoBar>
                <StackPanel IsEnabled="{Binding IsEnabled.Value}">

                    <TextBlock Text="テキスト" />
                    <TextBox MinHeight="200"
                             Margin="0,4,0,0"
                             VerticalContentAlignment="Top"
                             AcceptsReturn="True"
                             Text="{Binding Text.Value, Mode=TwoWay}"
                             TextWrapping="Wrap" />
                    <TextBlock Margin="0,16,0,0" Text="話者" />
                    <ComboBox Margin="0,4,0,0"
                              HorizontalAlignment="Stretch"
                              ItemsSource="{Binding Voice.Value}"
                              SelectedItem="{Binding SelectedVoice.Value, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:VoiceMetadata">
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Margin="0,16,0,0" Text="スタイル" />
                    <ComboBox Margin="0,4,0,0"
                              HorizontalAlignment="Stretch"
                              ItemsSource="{Binding SelectedVoice.Value.Styles}"
                              SelectedItem="{Binding SelectedStyle.Value, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:VoiceStyle">
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- AudioQuery generation button -->
                    <Button Margin="0,24,0,0"
                            Command="{Binding GenerateAudioQuery}"
                            IsEnabled="{Binding !IsGenerating.Value}">
                        <TextBlock Text="AudioQuery生成" />
                    </Button>

                    <!-- AudioQuery editor section -->
                    <Border Margin="0,16,0,0"
                            Padding="12"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            IsVisible="{Binding IsAudioQueryGenerated.Value}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold"
                                       Margin="0,0,0,8"
                                       Text="音声パラメータ" />
                            
                            <!-- Global parameters -->
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                                    <TextBlock Text="話速" />
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Slider Width="150"
                                                Minimum="0.5"
                                                Maximum="2.0"
                                                TickFrequency="0.1"
                                                Value="{Binding CurrentAudioQuery.Value.SpeedScale, Mode=TwoWay}" />
                                        <TextBlock Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding CurrentAudioQuery.Value.SpeedScale, StringFormat='{}{0:F2}'}" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
                                    <TextBlock Text="音高" />
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Slider Width="150"
                                                Minimum="-0.15"
                                                Maximum="0.15"
                                                TickFrequency="0.01"
                                                Value="{Binding CurrentAudioQuery.Value.PitchScale, Mode=TwoWay}" />
                                        <TextBlock Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding CurrentAudioQuery.Value.PitchScale, StringFormat='{}{0:F2}'}" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                                    <TextBlock Text="抑揚" />
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Slider Width="150"
                                                Minimum="0.0"
                                                Maximum="2.0"
                                                TickFrequency="0.1"
                                                Value="{Binding CurrentAudioQuery.Value.IntonationScale, Mode=TwoWay}" />
                                        <TextBlock Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding CurrentAudioQuery.Value.IntonationScale, StringFormat='{}{0:F2}'}" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,8">
                                    <TextBlock Text="音量" />
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Slider Width="150"
                                                Minimum="0.0"
                                                Maximum="2.0"
                                                TickFrequency="0.1"
                                                Value="{Binding CurrentAudioQuery.Value.VolumeScale, Mode=TwoWay}" />
                                        <TextBlock Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding CurrentAudioQuery.Value.VolumeScale, StringFormat='{}{0:F2}'}" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,8">
                                    <TextBlock Text="前の無音（秒）" />
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Slider Width="150"
                                                Minimum="0.0"
                                                Maximum="1.5"
                                                TickFrequency="0.01"
                                                Value="{Binding CurrentAudioQuery.Value.PrePhonemeLength, Mode=TwoWay}" />
                                        <TextBlock Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding CurrentAudioQuery.Value.PrePhonemeLength, StringFormat='{}{0:F2}'}" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,8">
                                    <TextBlock Text="後の無音（秒）" />
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Slider Width="150"
                                                Minimum="0.0"
                                                Maximum="1.5"
                                                TickFrequency="0.01"
                                                Value="{Binding CurrentAudioQuery.Value.PostPhonemeLength, Mode=TwoWay}" />
                                        <TextBlock Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding CurrentAudioQuery.Value.PostPhonemeLength, StringFormat='{}{0:F2}'}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Accent phrases editor -->
                            <TextBlock FontWeight="Bold"
                                       Margin="0,16,0,8"
                                       Text="アクセント句" />
                            <ItemsControl ItemsSource="{Binding AccentPhrases}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:AccentPhraseViewModel">
                                        <Border Margin="0,0,0,8"
                                                Padding="8"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                                BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding DisplayText}" />
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <TextBlock Text="アクセント位置: " />
                                                    <NumericUpDown Width="80"
                                                                   Minimum="0"
                                                                   Maximum="{Binding MaxAccentPosition}"
                                                                   Value="{Binding Accent.Value, Mode=TwoWay}" />
                                                    <CheckBox Margin="16,0,0,0"
                                                              Content="疑問文"
                                                              IsChecked="{Binding IsInterrogative.Value, Mode=TwoWay}" />
                                                </StackPanel>
                                                
                                                <!-- Mora pitch editor -->
                                                <TextBlock Margin="0,8,0,4" Text="モーラごとのピッチ:" />
                                                <ItemsControl ItemsSource="{Binding Moras}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="viewModels:MoraViewModel">
                                                            <Border Margin="0,0,4,4"
                                                                    Padding="4"
                                                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="2">
                                                                <StackPanel>
                                                                    <TextBlock HorizontalAlignment="Center"
                                                                               Text="{Binding Text.Value}" />
                                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                        <TextBlock Text="P:" FontSize="10" />
                                                                        <NumericUpDown Width="60"
                                                                                       FontSize="10"
                                                                                       Minimum="0"
                                                                                       Maximum="200"
                                                                                       Increment="1"
                                                                                       Value="{Binding Pitch.Value, Mode=TwoWay}"
                                                                                       FormatString="F0" />
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <WrapPanel Margin="0,24,0,0" Orientation="Horizontal">
                        <Button Classes="accent"
                                Command="{Binding Generate}"
                                IsEnabled="{Binding !IsGenerating.Value}">
                            <TextBlock Text="追加" />
                        </Button>
                        <Button Margin="4,0,0,0"
                                Command="{Binding Play}"
                                IsEnabled="{Binding !IsGenerating.Value}">
                            <TextBlock Text="読み上げ" />
                        </Button>
                    </WrapPanel>
                    <ProgressBar Margin="0,4,0,0"
                                 IsIndeterminate="{Binding IsGenerating.Value}"
                                 IsVisible="{Binding IsGenerating.Value}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>